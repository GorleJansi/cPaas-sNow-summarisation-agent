# ─── ServiceNow ────────────────────────────────────────────────
SERVICENOW_INSTANCE=dev380388.service-now.com
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your-servicenow-password

# ─── Webex Bot ─────────────────────────────────────────────────
